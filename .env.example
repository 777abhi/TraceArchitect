# Day 1 environment configuration for the local Ollama LLM backend.
# Copy this file to `.env` and adjust as needed:
#     cp .env.example .env
#
# `.env` is git-ignored so your local settings stay out of version control.

# Base URL of your local Ollama server.
OLLAMA_HOST=http://localhost:11434

# Small default model to pull and use for Day 1.
# Pull it once with:  ollama pull llama3.2
OLLAMA_MODEL=llama3.2
